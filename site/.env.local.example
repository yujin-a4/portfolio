# ──────────────────────────────────────────────
# AI 유진 인터뷰룸 (Gemini API)
# https://aistudio.google.com/app/apikey → API Keys
# ──────────────────────────────────────────────
GEMINI_API_KEY=

# 선택: 모델을 바꾸고 싶을 때만 설정
# GEMINI_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────
# Figma 이미지 연동
# Figma → Settings → Personal access tokens → Create token
# ──────────────────────────────────────────────
FIGMA_TOKEN=figd_...

# Figma 파일 키: Figma URL에서 /design/ 뒤 문자열
# 예: https://www.figma.com/design/AbCdEfGhIj.../포트폴리오
#                                  ^^^^^^^^^^^
NEXT_PUBLIC_FIGMA_FILE_KEY=

# ──────────────────────────────────────────────
# Vercel 재배포 훅 (Figma 변경 시 자동 반영)
# Vercel 대시보드 → 프로젝트 → Settings → Git → Deploy Hooks → 생성
# Figma Webhooks에 이 URL 등록하면 Figma 저장 시 자동 재배포
# ──────────────────────────────────────────────
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
